# Sanity (M5 / M6) — create a project at sanity.io and paste the ID here
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# Contact form (M7) — Web3Forms is the default
# get a free access key at web3forms.com (no account required)
WEB3FORMS_ACCESS_KEY=

# Optional: Resend as an alternative to Web3Forms
# RESEND_API_KEY=

# Optional analytics
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=orbitalartifacts.shop
