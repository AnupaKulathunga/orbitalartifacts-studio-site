# Sanity (M5 / M6) — create a project at sanity.io and paste the ID here
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# Contact form (M7) — Web3Forms is the default
# get a free access key at web3forms.com (no account required).
# Web3Forms free tier only supports client-side submissions, so the key
# must be exposed to the browser via the NEXT_PUBLIC_ prefix. It is safe
# to expose — it's an account identifier, not a secret.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# Optional: Resend as an alternative to Web3Forms
# RESEND_API_KEY=

# Shared password for /curate (back-office pick-list tool).
# - Required on Vercel Preview so the route is gated behind an access code.
# - Not required for local `next dev` — the gate is bypassed when unset.
# - Never reached on Production; /curate 404s on VERCEL_ENV=production
#   regardless of whether this is set.
CURATE_PASSWORD=

# Optional analytics
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=orbitalartifacts.shop
